manifest {
    name        = 'het-site-pipeline2'
    author      = 'Nadeem Khan'
    description = 'Heterozygous site counting pipeline from gVCF cohorts'
    version     = '1.0.0'
    nextflowVersion = '>=23.0.0'
}

params {
    cohorts     = "Cohort_A,Cohort_B"
    results_dir = "results"
    min_dp      = 20
    min_gq      = 30
    chroms      = "chr1,chr2,chr3,chr4,chr5,chr6,chr7,chr8,chr9,chr10,chr11,chr12,chr13,chr14,chr15,chr16,chr17,chr18,chr19,chr20,chr21,chr22,chrX,chrY"
}

process {
    withLabel: 'process_low' {
        cpus   = 1
        memory = '2 GB'
        time   = '30 min'
    }
    withLabel: 'process_medium' {
        cpus   = 2
        memory = '8 GB'
        time   = '1 h'
    }
    withLabel: 'process_high' {
        cpus   = 4
        memory = '16 GB'
        time   = '2 h'
    }
}

profiles {

    local {
        process.executor = 'local'
        executor {
            cpus   = 8
            memory = '32 GB'
        }
    }

    slurm {
        process.executor   = 'slurm'
        clusterOptions     = '--account=def-fveyrier_cpu'

        executor {
            queueSize       = 500
            submitRateLimit = '10/1min'
        }

        process {
            withLabel: 'process_low' {
                cpus   = 1
                memory = '2 GB'
                time   = '30 min'
            }
            withLabel: 'process_medium' {
                cpus   = 2
                memory = '8 GB'
                time   = '1 h'
            }
            withLabel: 'process_high' {
                cpus   = 4
                memory = '16 GB'
                time   = '2 h'
            }
        }
    }

    test {
        params.chroms    = "chr1,chr22"
        process.executor = 'local'
    }
}

resume = true

report {
    enabled = true
    file    = "results/reports/execution_report.html"
}

timeline {
    enabled = true
    file    = "results/reports/timeline.html"
}

trace {
    enabled = true
    file    = "results/reports/trace.tsv"
    fields  = 'task_id,name,status,exit,realtime,cpus,%cpu,memory,%mem,rss'
}
